

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  RIDER
  DRIVER
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  roles              Role[]         @default([RIDER])
  driverProfile      DriverProfile?
  riderRides         Ride[]         @relation("RiderRides")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model DriverProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  vehicleModel String
  vehiclePlate String
  vehicleColor String
  rides        Ride[]   @relation("DriverRides")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum RideStatus {
  REQUESTED
  SEARCHING
  ASSIGNED
  TIMEOUT
  COMPLETED
  CANCELLED
}

model Ride {
  id        String     @id @default(uuid())
  riderId   String
  rider     User       @relation("RiderRides", fields: [riderId], references: [id])
  driverId  String?
  driver    DriverProfile? @relation("DriverRides", fields: [driverId], references: [userId])
  status    RideStatus @default(REQUESTED)
  pickupLat Float
  pickupLng Float
  dropLat   Float
  dropLng   Float
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
